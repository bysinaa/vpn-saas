# =============================================================================
# VPN SaaS - Environment Configuration (Template)
# Copy to .env and fill in real values. Never commit real secrets.
# =============================================================================

# ---------- Application ----------
NODE_ENV=development
APP_NAME=vpn-saas
APP_PORT=3000
APP_HOST=0.0.0.0
APP_URL=http://localhost:3000
API_PREFIX=api
API_VERSION=v1
GLOBAL_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=120

# ---------- Database (PostgreSQL) ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vpn_saas?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ---------- Redis / Cache ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL_DEFAULT=300

# ---------- JWT / Auth ----------
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=vpn-saas
JWT_AUDIENCE=vpn-saas-clients

# ---------- S3 Compatible Storage ----------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=vpn-saas
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/vpn-saas

# ---------- Telegram Bot ----------
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_BOT_WEBHOOK_URL=
TELEGRAM_BOT_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_BOT_USE_WEBHOOK=false
TELEGRAM_ADMIN_IDS=123456789,987654321
TELEGRAM_MINI_APP_URL=https://t.me/vpn_saas_bot/app

# ---------- Sanity VPN Panel Integration ----------
SANITY_PANEL_BASE_URL=https://panel.example.com
SANITY_PANEL_API_KEY=change-me
SANITY_PANEL_TIMEOUT_MS=15000
SANITY_PANEL_MAX_RETRIES=3
SANITY_PANEL_SYNC_CRON=0 */6 * * *

# ---------- Payment Gateways ----------
# Online gateway
ONLINE_GATEWAY_ENABLED=true
ONLINE_GATEWAY_BASE_URL=https://pay.example.com
ONLINE_GATEWAY_MERCHANT_ID=change-me
ONLINE_GATEWAY_API_KEY=change-me
ONLINE_GATEWAY_CALLBACK_URL=http://localhost:3000/api/v1/payments/online/callback

# Crypto
CRYPTO_ENABLED=true
CRYPTO_API_BASE_URL=https://api.crypto-pay.example.com
CRYPTO_API_KEY=change-me
CRYPTO_WEBHOOK_SECRET=change-me

# Card to card (admin-managed, no gateway)
CARD_TO_CARD_ENABLED=true
CARD_TO_CARD_CARD_NUMBER=0000-0000-0000-0000
CARD_TO_CARD_HOLDER_NAME=Company Name

# ---------- Security ----------
BCRYPT_ROUNDS=12
WEBHOOK_SECRET=change-me
ENCRYPTION_KEY=change-me-32-byte-encryption-key-here
COOKIE_SECURE=false
CSRF_ENABLED=false

# ---------- Storage Limits ----------
MAX_UPLOAD_SIZE_MB=10
RECEIPT_ALLOWED_MIMES=image/jpeg,image/png,image/webp,application/pdf

# ---------- Queue / BullMQ ----------
QUEUE_PREFIX=vpn-saas
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF=exponential
QUEUE_DEFAULT_BACKOFF_DELAY=5000

# ---------- Monitoring ----------
PINO_LEVEL=info
PINO_PRETTY=true
PROMETHEUS_ENABLED=true
PROMETHEUS_PATH=/metrics
HEALTH_CHECK_PATH=/health
BULL_BOARD_PATH=/admin/queues

# ---------- Super Admin (seed) ----------
SUPER_ADMIN_EMAIL=admin@vpn-saas.local
SUPER_ADMIN_PASSWORD=ChangeMe!2024
SUPER_ADMIN_TELEGRAM_ID=123456789
