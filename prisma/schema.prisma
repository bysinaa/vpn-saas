// =============================================================================
// VPN SaaS - Prisma Schema
// PostgreSQL | Normalized | Indexed | Foreign Keys | Migration Ready
// =============================================================================
// Design principles:
//  - Every business concept is its own model (Single Responsibility)
//  - Money is stored as BigInteger "minor units" to avoid float rounding
//  - Status / type fields use Enums for type-safety and DB-level validation
//  - Soft-delete via deletedAt on business-critical tables
//  - Audit columns (createdAt/updatedAt) on every table
//  - Indexes on foreign keys and frequent filter columns
//  - UUID public identifiers (publicId) vs sequential PKs for security/perf
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// CENTRALIZED RUNTIME CONFIGURATION (3X-UI style settings table)
// Loaded by ConfigService. Sensitive values are stored encrypted (AES-256-GCM).
// =============================================================================

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String?
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@index([key])
  @@map("settings")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  SUPPORT
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING
  DELETED
}

enum Language {
  EN
  FA
  RU
  AR
  TR
}

enum WalletTxnType {
  DEPOSIT
  WITHDRAW
  PURCHASE
  REFUND
  BONUS
  CASHBACK
  REFERRAL_REWARD
  GIFT
  ADJUSTMENT
  VOUCHER_REDEEM
}

enum WalletTxnStatus {
  PENDING
  CONFIRMED
  FAILED
  REVERSED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

enum OrderType {
  NEW
  RENEW
  UPGRADE
  EXTEND
  GIFT
  TRIAL
  TRANSFER
}

enum PaymentMethod {
